# =============================================================================
# VerMillion CRM — תבנית משתני סביבה
# =============================================================================
# העתק לקובץ `.env` בשורש הפרויקט (לא נכנס ל-Git).
# מלא ערכים אמיתיים רק ב-.env — לעולם לא להדביק סודות בקובץ זה.
#
# יצירת AUTH_SECRET (PowerShell):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =============================================================================

# --- מסד נתונים מקומי (Prisma / SQLite) ---
DATABASE_URL="file:./dev.db"

# --- התחברות ל-CRM (NextAuth) ---
# מחרוזת אקראית לחתימת JWT — חובה בפרודקשן
AUTH_SECRET=

# מנכ״ל — התחברות עם שם משתמש + סיסמה (לא נשמר ב-Employee)
CRM_ADMIN_USERNAME=
CRM_ADMIN_PASSWORD=

# תאימות: אם CRM_ADMIN_USERNAME ריק, אפשר להשתמש באימייל כשם משתמש
# CRM_ADMIN_EMAIL=

# --- בינה מלאכותית (סוכני CRM) ---
# ספק ברירת מחדל: grok | claude | auto
AI_PROVIDER=grok

# xAI Grok — מפתח מ-https://console.x.ai (משמש את הסוכנים כיום בקוד)
XAI_API_KEY=

# Groq — מפתח מ-https://console.groq.com (מתחיל ב-gsk_)
# הערה: כרגע הסוכנים ב-CRM קוראים ל-XAI_API_KEY / ANTHROPIC_API_KEY בלבד.
# אם תרצה Groq — הוסף כאן לתיעוד/שילוב עתידי; אל תשים את המפתח האמיתי בקובץ זה.
GROQ_API_KEY=

# Anthropic Claude — מפתח מ-https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- יניקת נתונים מאפליקציית VerMillion (Supabase, שרת בלבד) ---
# URL של פרויקט Supabase של האפליקציה
VERMILLION_INGESTION_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# מפתח service_role — רק בשרת, לעולם לא בדפדפן
VERMILLION_INGESTION_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# כתובת האפליקציה בפרודקשן (קישורים בממשק)
VERMILLION_APP_URL=https://your-app.vercel.app

# סנכרון אוטומטי מ-Supabase Realtime (true | false)
# דורש הפעלת Realtime על: profiles, commitment, daily_stamps,
# onboarding_state, onboarding_answers, chat_history, financial_data, game_sessions
VERMILLION_REALTIME_SYNC=true

# --- אופציונלי ---
# NEXT_PUBLIC_VERMILLION_APP_URL=
# VERMILLION_API_KEY=
# WHATSAPP_PROVIDER=stub
